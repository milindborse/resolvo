# Database
DB_URL=jdbc:postgresql://localhost:5432/resolvo
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace-with-a-long-random-base64-string
JWT_EXPIRATION_MS=86400000

# Cloudinary (https://cloudinary.com free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (Gmail app password, or any free SMTP provider)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@resolvo.app

# Business config
OVERDUE_THRESHOLD_DAYS=5
PORT=8080
